{
  // Workspaces
  "hyprland/workspaces": {
    "on-click": "activate",
    "active-only": false,
    "all-outputs": true,
   	"format": "{icon}",
    "format-icons": {
      "1":  "1 пД†",
      "2": "2 пВђ",
      "3": "3 пА•",
      "4": "4 #",
      "5": "5 пЯВ"
    },
    "persistent-workspaces": {
      "*": 5
    }
  },
  "sway/workspaces": {
    "on-click": "activate",
    "active-only": false,
    "all-outputs": true,
    "disable-scroll": true,
    "format-icons": {
      "1": "1 пД†",
      "2": "2 пВђ",
      "3": "3 пА•",
      "4": "4 #",
      "5": "5 пЯВ",
    },
    "persistent-workspaces": {
      // "1": "1",
      // "2": "2",
      // "3": "3"
    }
  },
  "sway/mode": {
    "format": "<span style=\"italic\">{}</span>"
  },
  // Hyprland Window
  "hyprland/window": {
    "rewrite": {
      "(.*) - Discord": "# Discord: $1", 
      "Element | (.*)": "# Element: $1",
      "(.*) - ArmCord": "# Discord: $1",
      "Revolt": "# Revolt",
      "(.*) вАФ LibreWolf": "$1",
      "(.*) вАФ Mozilla Firefox": "$1",
      "(.*) вАФ Zen Browser": "$1",
      "(.*) - Chromium": "$1",
      "(.*) - Vivaldi": "$1",
      "Spotify (.*)": "Spotify",
      "(.*) - Tidal": "Tidal",
      "(.*) - TIDAL": "Tidal",
    },
    "separate-outputs": true
  },
  "sway/window": {
    "rewrite": {
      "(.*) - Discord": "# Discord: $1",
      "Element(.*)": "# Element: $1",
      "(.*) - ArmCord": "# Discord: $1",
      "Revolt": "# Revolt",
      "(.*) вАФ LibreWolf": "$1",
      "(.*) вАФ Mozilla Firefox": "$1",
      "(.*) вАФ Zen Browser": "$1",
      "(.*) - Chromium": "$1",
      "(.*) - Vivaldi": "$1",
      "Spotify (.*)": "Spotify",
      "(.*) - Tidal": "Tidal",
      "(.*) - TIDAL": "Tidal",
    },
    "separate-outputs": true
  },
  // Wofi Application Launcher
  "custom/appmenu": {
    "format": "Launch",
    "tooltip-format": "Left: Open the application launcher\nRight: Show all keybindings",
    "on-click": "anyrun",
    "on-click-right": "alacritty -e bat ~/.config/hypr/conf/binds.conf",
    "tooltip": true
  },
{{- if eq .chezmoi.hostname "Fennekin" }}
  "custom/osktoggle": {
    "format": "вАЙу∞ММ ",
    "on-click": "~/.config/hypr/scripts/keyboard-relaunch.sh",
    "tooltip-format": "Toggle the on-screen keyboard (restarts the keyboard if needed.)"
  },
{{- end }}
  // Power Menu
  "custom/exit": {
    "format": "пАС",
    "tooltip-format": "Powermenu",
    "on-click": "wlogout -b 4",
    "tooltip": false
  },
  // Keyboard State
  "keyboard-state": {
    "numlock": true,
    "capslock": true,
    "format": "{name} {icon}",
    "format-icons": {
      "locked": "пА£",
      "unlocked": "пВЬ"
    }
  },
  // System tray
  "tray": {
    // "icon-size": 21,
    "spacing": 10
  },
  // Clock
  "clock": {
    "timezone": "Europe/Berlin",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format-alt": "{:%Y-%m-%d}"
  },
  // System
  "custom/system": {
    "format": "оС≥",
    "tooltip": false
  },
  // CPU
  "cpu": {
    "format": "пЛЫ {usage}% ",
    "on-click": "alacritty -e htop"
  },
  // Memory
  "memory": {
    "format": "пФЄ {}% ",
    "on-click": "alacritty -e btop"
  },
  // Harddisc space used
  "disk": {
    "interval": 30,
    "format": "D {percentage_used}% ",
    "path": "/",
    "on-click": "alacritty -e htop"
  },
  "hyprland/language": {
    "format": "/ K {short}"
  },
  // Group Hardware
  "group/hardware": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 300,
      "children-class": "not-memory",
      "transition-left-to-right": false
    },
    "modules": [
      "custom/system",
      "disk",
      "cpu",
      "memory",
      "hyprland/language"
    ]
  },
  // Network
  "network": {
    "format": "{ifname}",
    "format-wifi": "пЗЂ ",
    "format-ethernet": " пЮЦ ",
    "format-disconnected": "Not connected",
    "tooltip-format": "пЮЦ {ifname} via {gwaddri}",
    "tooltip-format-wifi": "пЗЂ   {essid} ({signalStrength}%)",
    "tooltip-format-ethernet": "пГБ  {ifname} ({ipaddr}/{cidr})",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
    "on-click": "alacritty -e nmtui connect"
  },
  // Battery
  "battery": {
    "states": {
      "good": 80,
      "warning": 30,
      "critical": 15
    },
    "format-alt": "{icon} {capacity}%",
    "format": "{icon}  {time}",
    "format-charging": "пЗ¶  {capacity}%",
    "format-plugged": "пЗ¶  {capacity}%",
    // "format-good": "пЙА ",
    "format-full": "",
    "format-icons": [
      "пЙД ",
      "пЙГ ",
      "пЙВ ",
      "пЙБ ",
      "пЙА "
    ]
  },
  // Pulseaudio
  "pulseaudio": {
    // "scroll-step": 1, // %, can be a float
    "format": "{icon}  {volume}%",
    "format-bluetooth": "{volume}% {icon}пКФ {format_source}",
    "format-bluetooth-muted": "пЪ© {icon}пКФ",
    "format-muted": "пЪ© ",
    "format-source": "{volume}% пД∞",
    "format-source-muted": "пД±",
    "format-icons": {
      "headphone": "пА•",
      "hands-free": "пЦР",
      "headset": "пЦР",
      "phone": "пВХ",
      "portable": "пВХ",
      "car": "пЖє",
      "default": [
        "пА¶",
        "пА® ",
        "пА® "
      ]
    },
    "on-click": "pavucontrol"
  },
  // Bluetooth
  "bluetooth": {
    "format-disabled": "",
    "format-off": "",
    "interval": 30,
    "on-click": "blueman-manager",
    "format-no-controller": ""
  },
  // Other
  "user": {
    "format": "{user}",
    "interval": 60,
    "icon": false
  },
  // Idle Inhibator
  "idle_inhibitor": {
    "format": "{icon}",
    "tooltip": true,
    "format-icons": {
      "activated": "пПБ",
      "deactivated": "пА£"
    },
    "on-click-right": "hyprlock"
  }
}
