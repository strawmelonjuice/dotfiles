{
  // Workspaces
  "hyprland/workspaces": {
    "on-click": "activate",
    "active-only": false,
    "all-outputs": true,
   	"format": "{icon}",
    "format-icons": {
      "1":  "1 яДа",
      "2": "2 яВм",
      "3": "3 яАе",
      "4": "4 #",
      "5": "5 яЯВ"
    },
    "persistent-workspaces": {
      "*": 5
    }
  },
  "sway/workspaces": {
    "on-click": "activate",
    "active-only": false,
    "all-outputs": true,
    "disable-scroll": true,
    "format-icons": {
      "1": "1 яДа",
      "2": "2 яВм",
      "3": "3 яАе",
      "4": "4 #",
      "5": "5 яЯВ",
    },
    "persistent-workspaces": {
      // "1": "1",
      // "2": "2",
      // "3": "3"
    }
  },
  "sway/mode": {
    "format": "<span style=\"italic\">{}</span>"
  },
  // Hyprland Window
  "hyprland/window": {
    "rewrite": {
      "(.*) - Discord": "# Discord: $1", 
      "(.*) - ArmCord": "# Discord: $1",
      "Revolt": "# Revolt",
      "(.*) тАФ LibreWolf": "$1",
      "(.*) тАФ Mozilla Firefox": "$1",
      "(.*) тАФ Zen Browser": "$1",
      "(.*) - Chromium": "$1",
      "(.*) - Vivaldi": "$1",
      "Spotify (.*)": "Spotify",
      "(.*) - Tidal": "Tidal",
      "(.*) - TIDAL": "Tidal",
    },
    "separate-outputs": true
  },
  "sway/window": {
    "rewrite": {
      "(.*) - Discord": "# Discord: $1",
      "(.*) - ArmCord": "# Discord: $1",
      "Revolt": "# Revolt",
      "(.*) тАФ LibreWolf": "$1",
      "(.*) тАФ Mozilla Firefox": "$1",
      "(.*) тАФ Zen Browser": "$1",
      "(.*) - Chromium": "$1",
      "(.*) - Vivaldi": "$1",
      "Spotify (.*)": "Spotify",
      "(.*) - Tidal": "Tidal",
      "(.*) - TIDAL": "Tidal",
    },
    "separate-outputs": true
  },
  // Wofi Application Launcher
  "custom/appmenu": {
    "format": "Launch",
    "tooltip-format": "Left: Open the application launcher\nRight: Show all keybindings",
    "on-click": "anyrun",
    "on-click-right": "alacritty -e bat ~/.config/hypr/conf/binds.conf",
    "tooltip": true
  },
{{- if eq .chezmoi.hostname "Fennekin" }}
  "custom/osktoggle": {
    "format": "тАЙґ░ММ ",
    "on-click": "~/.config/hypr/scripts/keyboard-relaunch.sh",
    "tooltip-format": "Toggle the on-screen keyboard (restarts the keyboard if needed.)"
  },
{{- end }}
  // Power Menu
  "custom/exit": {
    "format": "яАС",
    "tooltip-format": "Powermenu",
    "on-click": "wlogout -b 4",
    "tooltip": false
  },
  // Keyboard State
  "keyboard-state": {
    "numlock": true,
    "capslock": true,
    "format": "{name} {icon}",
    "format-icons": {
      "locked": "яАг",
      "unlocked": "яВЬ"
    }
  },
  // System tray
  "tray": {
    // "icon-size": 21,
    "spacing": 10
  },
  // Clock
  "clock": {
    "timezone": "Europe/Berlin",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format-alt": "{:%Y-%m-%d}"
  },
  // System
  "custom/system": {
    "format": "юС│",
    "tooltip": false
  },
  // CPU
  "cpu": {
    "format": "яЛЫ {usage}% ",
    "on-click": "alacritty -e htop"
  },
  // Memory
  "memory": {
    "format": "яФ╕ {}% ",
    "on-click": "alacritty -e btop"
  },
  // Harddisc space used
  "disk": {
    "interval": 30,
    "format": "D {percentage_used}% ",
    "path": "/",
    "on-click": "alacritty -e htop"
  },
  "hyprland/language": {
    "format": "/ K {short}"
  },
  // Group Hardware
  "group/hardware": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 300,
      "children-class": "not-memory",
      "transition-left-to-right": false
    },
    "modules": [
      "custom/system",
      "disk",
      "cpu",
      "memory",
      "hyprland/language"
    ]
  },
  // Network
  "network": {
    "format": "{ifname}",
    "format-wifi": "яЗл ",
    "format-ethernet": " яЮЦ ",
    "format-disconnected": "Not connected",
    "tooltip-format": "яЮЦ {ifname} via {gwaddri}",
    "tooltip-format-wifi": "яЗл   {essid} ({signalStrength}%)",
    "tooltip-format-ethernet": "яГБ  {ifname} ({ipaddr}/{cidr})",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
    "on-click": "alacritty -e nmtui connect"
  },
  // Battery
  "battery": {
    "states": {
      "good": 80,
      "warning": 30,
      "critical": 15
    },
    "format-alt": "{icon} {capacity}%",
    "format": "{icon}  {time}",
    "format-charging": "яЗж  {capacity}%",
    "format-plugged": "яЗж  {capacity}%",
    // "format-good": "яЙА ",
    "format-full": "",
    "format-icons": [
      "яЙД ",
      "яЙГ ",
      "яЙВ ",
      "яЙБ ",
      "яЙА "
    ]
  },
  // Pulseaudio
  "pulseaudio": {
    // "scroll-step": 1, // %, can be a float
    "format": "{icon}  {volume}%",
    "format-bluetooth": "{volume}% {icon}яКФ {format_source}",
    "format-bluetooth-muted": "яЪй {icon}яКФ",
    "format-muted": "яЪй ",
    "format-source": "{volume}% яД░",
    "format-source-muted": "яД▒",
    "format-icons": {
      "headphone": "яАе",
      "hands-free": "яЦР",
      "headset": "яЦР",
      "phone": "яВХ",
      "portable": "яВХ",
      "car": "яЖ╣",
      "default": [
        "яАж",
        "яАи ",
        "яАи "
      ]
    },
    "on-click": "pavucontrol"
  },
  // Bluetooth
  "bluetooth": {
    "format-disabled": "",
    "format-off": "",
    "interval": 30,
    "on-click": "blueman-manager",
    "format-no-controller": ""
  },
  // Other
  "user": {
    "format": "{user}",
    "interval": 60,
    "icon": false
  },
  // Idle Inhibator
  "idle_inhibitor": {
    "format": "{icon}",
    "tooltip": true,
    "format-icons": {
      "activated": "яПБ",
      "deactivated": "яАг"
    },
    "on-click-right": "hyprlock"
  }
}
